{% extends "base.html.j2" %}

{% block title %}TrackLLM{% endblock %}

{% block content %}
        <h1>TrackLLM</h1>
        <p class="subtitle">Tracking LLM API logprob responses</p>

        <section class="endpoints-section">
            <h2>Tracked Endpoints <span class="count">({{ rows | length }})</span></h2>
            <table>
                <thead>
                    <tr>
                        <th>Model</th>
                        <th>Provider</th>
                        <th>LT</th>
                        <th>B3IT</th>
                    </tr>
                </thead>
                <tbody>
{% for row in rows %}
                    <tr>
                        <td><a href="endpoints/{{ row.slug }}.html">{{ row.model }}</a></td>
                        <td>{{ row.provider }}</td>
                        <td>{{ row.lt_status or "" }}</td>
                        <td>{{ row.b3it_status or "" }}</td>
                    </tr>
{% endfor %}
                </tbody>
            </table>
        </section>

{% if changes %}
        <section class="changes-section">
            <h2>Recent Changes</h2>
            <ul>
{% for c in changes %}
                <li>{{ c.date }} — {{ c.model }} ({{ c.method }})</li>
{% endfor %}
            </ul>
        </section>
{% endif %}
{% endblock %}
