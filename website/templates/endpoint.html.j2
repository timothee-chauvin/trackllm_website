{% extends "base.html.j2" %}

{% block title %}{{ model }} @ {{ provider }} | TrackLLM{% endblock %}

{% block content %}
        <a href="../index.html" class="back">← all endpoints</a>
        <h1>{{ model }}</h1>
        <p class="provider">@ {{ provider }}{% for m in methods %} <span class="badge method {{ m|lower }}">{{ m }}</span>{% endfor %}</p>

        <section id="b3it-section"></section>
        <div id="charts-container"></div>
{% endblock %}

{% block footer %}
            <a href="../index.html">← back to all endpoints</a>
{% endblock %}

{% block scripts %}
    <script type="application/json" id="manifest">{{ manifest_json | safe }}</script>
    <script type="module" src="../js/endpoint.js"></script>
{% endblock %}
